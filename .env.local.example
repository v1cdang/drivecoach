NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: speeding threshold in km/h (default 100)
NEXT_PUBLIC_SPEED_LIMIT_KMH=100

# Used to generate the magic-link redirect URL sent by Supabase.
# Set to your production URL on Vercel, e.g. https://drivecoach-theta.vercel.app
NEXT_PUBLIC_SITE_URL=https://drivecoach-theta.vercel.app

